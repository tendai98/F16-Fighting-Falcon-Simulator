rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This game uses a clean REST client. Browser clients should not read or
    // write replay storage directly. The Node backend uses Firebase Admin SDK,
    // which bypasses these client rules and performs validation before writes.
    match /replaySummaries/{replayId} {
      allow read, write: if false;
    }

    match /replayBlobs/{replayId} {
      allow read, write: if false;

      match /chunks/{chunkId} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
